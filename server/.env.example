# Copy this file to .env and fill in real values. .env is gitignored.

# Server
PORT=5000
# Comma-separated list of allowed frontend origins (only needed if the client is
# hosted separately from the API; same-origin requests are always allowed).
CLIENT_ORIGIN=http://localhost:5173
# Base URL used to build password-reset links. Optional: on Render, the app's own
# URL (RENDER_EXTERNAL_URL) is used automatically; in dev it defaults to the Vite
# client. Set only to override (e.g. a custom domain).
# APP_BASE_URL=https://your-domain.com

# Spoonacular Recipe API — https://spoonacular.com/food-api (free tier: 50 pts/day)
SPOONACULAR_API_KEY=your_spoonacular_api_key

# Yelp Fusion API key — https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key

# Brevo for sending email (password reset + shopping list). HTTPS API, so it
# works on hosts that block SMTP (e.g. Render's free tier). Verify a sender in
# Brevo — no domain required.
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM=your_verified_sender@example.com

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=your_atlas_connection_string
# Long random string used to sign login tokens. Generate one, keep it secret.
JWT_SECRET=change_me_to_a_long_random_string
