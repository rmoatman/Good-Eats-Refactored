# Copy this file to .env and fill in real values. .env is gitignored.

# Server
PORT=5000
# Comma-separated list of allowed frontend origins (Vite dev + your Render static site)
CLIENT_ORIGIN=http://localhost:5173

# Spoonacular Recipe API — https://spoonacular.com/food-api (free tier: 150 pts/day)
SPOONACULAR_API_KEY=your_spoonacular_api_key

# Yelp Fusion API key — https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key

# Gmail for sending the shopping list (App Password, NOT your login password):
# Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=your_atlas_connection_string
# Long random string used to sign login tokens. Generate one, keep it secret.
JWT_SECRET=change_me_to_a_long_random_string
